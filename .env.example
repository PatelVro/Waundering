# Cricket Pipeline — environment template
# Copy to .env (untracked) and fill in your values. NEVER commit .env.

# ---- Data ingest API keys ----
THE_ODDS_API_KEY=
CRICAPI_KEY=
NEWSAPI_KEY=
VISUAL_CROSSING_KEY=
OPENWEATHER_KEY=
STATSGURU_CONTACT=

# ---- Bet engine ----
# manual | paper | polymarket | betfair  (default: manual)
BET_MODE=manual
# Bankroll used for Kelly sizing (in your account currency)
BANKROLL=1000.0
# Minimum and maximum model-vs-book edge (in percentage points)
BET_EDGE_THRESHOLD_PP=3.0
BET_EDGE_MAX_PP=8.0
# Decimal-odds bounds (rejects degenerate or absurd lines)
BET_MIN_ODDS=1.20
BET_MAX_ODDS=8.00
# Kelly cap and per-bet stake cap (fraction of bankroll)
BET_KELLY_CAP=0.5
BET_MAX_STAKE_PCT=0.05

# ---- Polymarket (only if BET_MODE=polymarket) ----
# Storing private keys in plaintext env is not best practice; use a secrets
# manager in production. See docs for a hardware-wallet flow.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_WALLET_ADDR=
POLYMARKET_PRIVATE_KEY=
# Required safety acknowledgement before live placement
POLYMARKET_LIVE_CONFIRMED=

# ---- Optional overrides ----
# CRICKET_DB_PATH=/absolute/path/to/cricket.duckdb
# HTTP_BIND=127.0.0.1
