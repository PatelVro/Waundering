# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets — keep .env.example tracked, never .env
.env
.env.local

# Cricket pipeline data + cache (large, regenerable from cricsheet)
cricket_pipeline/data/*.duckdb
cricket_pipeline/data/*.duckdb.wal
cricket_pipeline/data/*.duckdb-wal
cricket_pipeline/data/cache/
cricket_pipeline/data/models/

# ----------------------------------------------------------------------
# Runtime state (changes every tick — useless to a remote agent + may
# contain bet / bankroll data).
# ----------------------------------------------------------------------
cricket_pipeline/work/runs/orchestrator_state.json
cricket_pipeline/work/runs/orchestrator_state.json.bak
cricket_pipeline/work/runs/orchestrator_state.json.tmp
cricket_pipeline/work/runs/orchestrator.pid
cricket_pipeline/work/runs/live_match.json
cricket_pipeline/work/runs/live_matches.json
cricket_pipeline/work/runs/match_timeline.jsonl
cricket_pipeline/work/runs/walk_forward/

# Log files (rotated by RotatingFileHandler)
*.log
*.log.[0-9]*
ball-train.log
cloudflared*.log
live-tracker.log
match-train*.log
tunnel.log

# Live dashboard data — contains bets / bankroll / PnL. Regenerated by
# export_dashboard_data on every tick.
data.json
data/data.json
data/preds/
predictions/

# ----------------------------------------------------------------------
# Allow cycle-analysis outputs and learnings — these are methodology
# context for remote agents (no PII, small, regenerable but valuable).
# Anything else under runs/ is treated as runtime state and ignored.
# Re-include explicitly with !pattern below if needed.
# ----------------------------------------------------------------------
# (no extra block lines needed; the explicit deny-list above is enough)

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude session metadata
.claude/
